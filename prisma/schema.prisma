// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserType {
  CUSTOMER
  FIXER
  ADMIN
}

enum Timeline {
  URGENT
  THIS_WEEK
  NO_RUSH
}

enum Mobility {
  BRING_TO_FIXER
  FIXER_COMES_TO_ME
}

enum RepairRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JobStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  REFUNDED
}

enum DisputeResolution {
  PENDING
  FIXER_OFFERED
  FIXER_REJECTED
  ESCALATED
  REFUNDED
  PARTIAL_REFUND
  RELEASED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
}

// Models
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  name         String
  avatarUrl    String?
  phone        String?
  locationLat  Float?
  locationLng  Float?
  city         String?
  userType     UserType  @default(CUSTOMER)
  isBanned     Boolean   @default(false)
  provider     String?
  providerId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  fixerProfile        FixerProfile?
  repairRequests      RepairRequest[]
  offers              Offer[]
  jobsAsCustomer      Job[]           @relation("CustomerJobs")
  jobsAsFixer         Job[]           @relation("FixerJobs")
  conversationsAsCustomer Conversation[] @relation("CustomerConversations")
  conversationsAsFixer    Conversation[] @relation("FixerConversations")
  messagesSent        Message[]
  reviewsGiven        Review[]        @relation("ReviewsGiven")
  reviewsReceived     Review[]        @relation("ReviewsReceived")
  disputesOpened      Dispute[]
  paymentsAsCustomer  Payment[]       @relation("CustomerPayments")
  paymentsAsFixer     Payment[]       @relation("FixerPayments")
  notifications       Notification[]
  accounts            Account[]
  sessions            Session[]
  staffMember         StaffMember?
  createdRoles        StaffRole[]     @relation("RoleCreator")
  voucherRedemptions  VoucherRedemption[]
  credits             UserCredit[]
  adminLogs           AdminLog[]

  @@index([email])
  @@index([userType])
  @@index([city])
}

// NextAuth Models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FixerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  kvkNumber       String?
  kvkVerified     Boolean  @default(false)
  btwNumber       String?
  bio             String?  @db.Text
  skills          String[]
  serviceRadiusKm Int      @default(10)
  minJobFee       Float?
  averageRating   Float    @default(0)
  totalJobs       Int      @default(0)
  totalEarnings   Float    @default(0)
  isActive        Boolean  @default(true)
  verifiedBadge   Boolean  @default(false)
  availability    Json?    // e.g. [{ day: "MON", startTime: "09:00", endTime: "17:00" }]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  nameNl      String
  slug        String    @unique
  iconUrl     String?
  description String?
  isActive    Boolean   @default(true)

  // Relations
  repairRequests RepairRequest[]

  @@index([isActive])
  @@index([slug])
}

model RepairRequest {
  id           String              @id @default(uuid())
  customerId   String
  title        String
  description  String              @db.Text
  categoryId   String
  photos       String[]
  videoUrl     String?
  locationLat  Float
  locationLng  Float
  city         String
  address      String?
  timeline     Timeline
  mobility     Mobility
  status       RepairRequestStatus @default(OPEN)
  aiDiagnosis  Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Relations
  customer      User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id])
  offers        Offer[]
  jobs          Job[]
  conversations Conversation[]

  @@index([customerId])
  @@index([categoryId])
  @@index([status])
  @@index([city])
  @@index([createdAt])
}

model Offer {
  id              String      @id @default(uuid())
  repairRequestId String
  fixerId         String
  price           Float
  estimatedTime   String
  message         String      @db.Text
  suggestedTimes  Json?       // Array of ISO date strings: ["2026-03-10T09:00:00Z", ...]
  status          OfferStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  // Relations
  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  fixer         User          @relation(fields: [fixerId], references: [id], onDelete: Cascade)
  jobs          Job[]

  @@index([repairRequestId])
  @@index([fixerId])
  @@index([status])
  @@index([createdAt])
}

model Job {
  id              String     @id @default(uuid())
  repairRequestId String
  offerId         String
  customerId      String
  fixerId         String
  agreedPrice     Float
  platformFee     Float
  fixerPayout     Float
  status          JobStatus  @default(SCHEDULED)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt       DateTime?
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?
  createdAt         DateTime   @default(now())

  // Relations
  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id])
  offer         Offer         @relation(fields: [offerId], references: [id])
  customer      User          @relation("CustomerJobs", fields: [customerId], references: [id])
  fixer         User          @relation("FixerJobs", fields: [fixerId], references: [id])
  reviews       Review[]
  disputes      Dispute[]
  payments      Payment[]

  @@index([repairRequestId])
  @@index([offerId])
  @@index([customerId])
  @@index([fixerId])
  @@index([status])
  @@index([status, scheduledAt])
  @@index([createdAt])
}

model Conversation {
  id              String   @id @default(uuid())
  repairRequestId String
  customerId      String
  fixerId         String
  createdAt       DateTime @default(now())

  // Relations
  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  customer      User          @relation("CustomerConversations", fields: [customerId], references: [id])
  fixer         User          @relation("FixerConversations", fields: [fixerId], references: [id])
  messages      Message[]

  @@index([repairRequestId])
  @@index([customerId])
  @@index([fixerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  photoUrl       String?
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([read])
  @@index([createdAt])
}

model Review {
  id         String   @id @default(uuid())
  jobId      String
  reviewerId String
  reviewedId String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  // Relations
  job      Job  @relation(fields: [jobId], references: [id])
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewed User @relation("ReviewsReceived", fields: [reviewedId], references: [id])

  @@index([jobId])
  @@index([reviewerId])
  @@index([reviewedId])
  @@index([rating])
}

model Dispute {
  id             String             @id @default(uuid())
  jobId          String
  openedById     String
  reason         String             @db.Text
  evidencePhotos String[]
  resolution     DisputeResolution  @default(PENDING)
  adminNotes     String?            @db.Text
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())

  // Fixer response
  fixerResponseType   String?
  fixerRefundAmount   Float?
  fixerMessage        String?            @db.Text
  fixerRespondedAt    DateTime?

  // Customer response to fixer offer
  customerAccepted    Boolean?
  customerMessage     String?            @db.Text
  customerRespondedAt DateTime?

  // Escalation tracking
  escalatedAt         DateTime?
  escalationReason    String?

  // Relations
  job      Job  @relation(fields: [jobId], references: [id])
  openedBy User @relation(fields: [openedById], references: [id])

  @@index([jobId])
  @@index([openedById])
  @@index([resolution])
}

model Payment {
  id                String        @id @default(uuid())
  jobId             String
  customerId        String
  fixerId           String
  amount            Float
  platformFee       Float
  fixerPayout       Float
  paymentProviderId String?
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  releasedAt        DateTime?

  // Relations
  job      Job  @relation(fields: [jobId], references: [id])
  customer User @relation("CustomerPayments", fields: [customerId], references: [id])
  fixer    User @relation("FixerPayments", fields: [fixerId], references: [id])

  @@index([jobId])
  @@index([customerId])
  @@index([fixerId])
  @@index([status])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  relatedId String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// Staff Management Models
model StaffRole {
  id           String   @id @default(uuid())
  name         String   // "Dispute Manager", "Content Editor", "Finance Officer", etc.
  description  String?
  permissions  Json     // Array of permission strings
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  creator      User          @relation("RoleCreator", fields: [createdBy], references: [id])
  staffMembers StaffMember[]

  @@index([name])
  @@index([createdBy])
}

model StaffMember {
  id        String   @id @default(uuid())
  userId    String   @unique
  roleId    String
  isActive  Boolean  @default(true)
  notes     String?  // "Hired for summer", "Part-time", etc.
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role StaffRole @relation(fields: [roleId], references: [id])

  @@index([userId])
  @@index([roleId])
  @@index([isActive])
}

// Platform Settings Model
model PlatformSettings {
  id                    String   @id @default("default")
  commissionPercentage  Float    @default(15)
  minJobFee             Float    @default(0)
  maxJobFee             Float?
  autoReleaseHours      Int      @default(72)
  maxPhotosPerRequest   Int      @default(5)
  maxVideoSeconds       Int      @default(60)
  maxOffersPerRequest   Int      @default(20)
  disputeWindowHours    Int      @default(72)
  repairVatRate         Float    @default(9)
  reviewEditDays        Int      @default(7)
  accountDeletionDays   Int      @default(30)
  requireKvk            Boolean  @default(true)
  allowUnverifiedFixers Boolean  @default(true)
  minFixerRating        Float    @default(0)
  activeCities          Json     @default("[\"Amsterdam\"]")
  notificationSettings  Json     @default("{\"welcome\":true,\"newOffer\":true,\"offerAccepted\":true,\"jobCompleted\":true,\"reviewReceived\":true,\"disputeUpdates\":true,\"appointmentReminder\":true}")
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

// Voucher & Credit Models
model Voucher {
  id              String              @id @default(uuid())
  code            String              @unique
  type            String              // "percentage" or "fixed"
  value           Float               // 10 (means 10% or €10 depending on type)
  maxUses         Int?                // null = unlimited
  usedCount       Int                 @default(0)
  minOrderValue   Float?              // minimum repair price to use this voucher
  validFrom       DateTime            @default(now())
  validUntil      DateTime?
  isActive        Boolean             @default(true)
  createdBy       String
  applicableTo    String              @default("all") // "all", "customers", "fixers"
  description     String?
  createdAt       DateTime            @default(now())

  // Relations
  redemptions VoucherRedemption[]

  @@index([code])
  @@index([isActive])
  @@index([createdBy])
}

model VoucherRedemption {
  id        String   @id @default(uuid())
  voucherId String
  userId    String
  jobId     String?
  amount    Float    // actual discount amount applied
  createdAt DateTime @default(now())

  // Relations
  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([userId])
  @@index([jobId])
  @@index([createdAt])
}

model UserCredit {
  id        String   @id @default(uuid())
  userId    String
  amount    Float    // positive = credit added, negative = credit used
  balance   Float    // running balance after this transaction
  reason    String   // "Admin gift", "Refund bonus", "Voucher reward", etc.
  createdBy String?  // admin who added it
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Site Content Model (CMS)
model SiteContent {
  id        String   @id // "hero_title", "hero_subtitle", "hero_image", etc.
  section   String   // "homepage", "how_it_works", "footer", etc.
  type      String   // "text", "image", "html"
  value     String   @db.Text // the actual content (text string or image URL)
  label     String   // human-readable label: "Homepage Hero Title"
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@index([section])
  @@index([type])
}

// Admin Activity Log Model
model AdminLog {
  id         String   @id @default(uuid())
  userId     String   // who did this action
  action     String   // "banned_user", "resolved_dispute", "changed_commission", etc.
  target     String?  // the ID of the affected record
  targetType String?  // "user", "job", "dispute", "setting", etc.
  details    Json?    // any extra info about what changed
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}
