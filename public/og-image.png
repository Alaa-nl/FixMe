<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="1200" height="630" fill="#1B4965"/>

  <!-- FixMe Logo Text -->
  <text x="600" y="280" font-family="Arial, sans-serif" font-size="120" font-weight="bold" fill="white" text-anchor="middle">
    FixMe
  </text>

  <!-- Tagline -->
  <text x="600" y="360" font-family="Arial, sans-serif" font-size="48" fill="#FF6B35" text-anchor="middle">
