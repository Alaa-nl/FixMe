# Database Configuration
# For local development with PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/fixme
# For Vercel Postgres (automatically set by Vercel):
DATABASE_URL=postgres://default:password@host.region.postgres.vercel-storage.com:5432/verceldb

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# Generate a secure secret key with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# ============================================================
# GOOGLE OAUTH SETUP (OPTIONAL BUT RECOMMENDED)
# ============================================================
# To enable Google sign-in, follow these steps:
#
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new project or select an existing one
# 3. Click "CREATE CREDENTIALS" → "OAuth 2.0 Client ID"
# 4. Choose "Web application" as the application type
# 5. Set the following Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (for development)
#    - https://yourdomain.com/api/auth/callback/google (for production)
# 6. Click "Create" and copy the Client ID and Client Secret below
#
# IMPORTANT: Replace the placeholder values below with your actual credentials
# If you leave them as placeholders, Google sign-in will be disabled automatically
#
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# APPLE OAUTH (NOT IMPLEMENTED - REQUIRES $99/YEAR DEVELOPER ACCOUNT)
# ============================================================
# Apple sign-in is disabled by default and buttons are hidden
# To enable it later, you'll need:
# 1. Apple Developer account ($99/year)
# 2. App ID and Service ID configured
# 3. Private key generated
# 4. Update src/lib/auth.ts to re-enable Apple provider
#
# APPLE_CLIENT_ID=not-configured
# APPLE_CLIENT_SECRET=not-configured

# ============================================================
# AI FEATURES (OPTIONAL)
# ============================================================
# Anthropic API for AI-powered repair diagnosis
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key